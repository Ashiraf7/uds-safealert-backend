# ── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://safealert:password@localhost:5432/safealert_db
# Or split form:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=safealert_db
# DB_USER=safealert
# DB_PASSWORD=password

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ── Alert radius (metres) ────────────────────────────
DEFAULT_ALERT_RADIUS_M=500
MAX_ALERT_RADIUS_M=5000

# ── OTP (optional — stub by default) ─────────────────
# OTP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_FROM=+1234567890
